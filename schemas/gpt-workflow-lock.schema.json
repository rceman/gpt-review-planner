{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rceman/gpt-review-planner/schemas/gpt-workflow-lock.schema.json",
  "title": "GPT Review Planner Project Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "version",
    "commit",
    "document",
    "installed_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "document": {
      "const": "GPT_REVIEW_PLANNER.md"
    },
    "installed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
